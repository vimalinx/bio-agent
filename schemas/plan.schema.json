{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bio-agent.local/schemas/plan.schema.json",
  "title": "Bio Skill System Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_id",
    "request_id",
    "title",
    "summary",
    "strategy_type",
    "stages",
    "approval_state"
  ],
  "properties": {
    "plan_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "source_workflow_id": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "strategy_type": {
      "type": "string",
      "enum": ["conservative", "efficient", "exploratory"]
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "expected_outputs": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "estimated_cost": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "time": { "type": "string" },
        "compute": { "type": "string" }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage_id", "name", "goal", "candidate_skills", "validation"],
        "properties": {
          "stage_id": { "type": "string" },
          "name": { "type": "string" },
          "goal": { "type": "string" },
          "candidate_skills": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "requires_user_confirmation": {
            "type": "boolean",
            "default": false
          },
          "outputs": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "validation": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      }
    },
    "approval_state": {
      "type": "string",
      "enum": ["draft", "selected", "approved"]
    }
  }
}
